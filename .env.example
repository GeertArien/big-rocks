# BigRocks environment configuration.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- Database ---------------------------------------------------------------
# SQLite to start. Swap the provider + URL for Postgres later without code changes.
# SQLite example:   file:./dev.db   (resolved relative to packages/core/prisma)
# Postgres example: postgresql://user:password@localhost:5432/bigrocks?schema=public
DATABASE_URL="file:./dev.db"

# --- Server -----------------------------------------------------------------
# Port the Fastify server listens on (also serves the built frontend in prod).
PORT=3000
HOST=0.0.0.0
# Where the built frontend lives, relative to the server. Set in the Docker image.
# WEB_DIST_PATH=../web/dist

# --- Auth -------------------------------------------------------------------
# Bearer token for the REST API (single-user model). Generate a long random value.
API_AUTH_TOKEN="change-me-to-a-long-random-token"

# --- AI (Anthropic) ---------------------------------------------------------
# Server-side only. Never commit. Leave blank to disable AI features.
ANTHROPIC_API_KEY=""
# Optional model override (defaults to claude-opus-4-8).
# ANTHROPIC_MODEL="claude-opus-4-8"
