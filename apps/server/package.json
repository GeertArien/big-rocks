{
  "name": "@big-rocks/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Fastify HTTP layer. Thin route handlers that call the shared @big-rocks/core service layer; serves the built frontend in production.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@big-rocks/core": "workspace:*",
    "@fastify/static": "^8.0.3",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@prisma/client": "^6.1.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/web-push": "^3.6.4",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
