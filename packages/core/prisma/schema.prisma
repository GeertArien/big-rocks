// Clock & Compass data model.
//
// Provider is SQLite to start; keep all access behind the repository/service
// layer so swapping to Postgres is just a provider + DATABASE_URL change.
//
// Modeling decisions locked in with the owner:
//   - quadrant is DERIVED from `important` x `urgent` (never stored).
//   - recurring commitments are tracked PER-PERSON (CommitmentLog.personId set).
//   - adherence is a streak/history view derived from logs (no per-period rows).

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TaskStatus {
  TODO
  DONE
  ARCHIVED
}

enum GoalStatus {
  ACTIVE
  ON_HOLD
  ACHIEVED
  DROPPED
}

enum ProjectStatus {
  ACTIVE
  SOMEDAY
  DONE
}

// Habit 1: is this within your influence (actionable) or just a concern?
enum ProactivityTag {
  INFLUENCE
  CONCERN
}

enum TaskSource {
  MANUAL
  TODOIST
  AI_INTAKE
}

enum CadenceUnit {
  DAY
  WEEK
  MONTH
}

enum RenewalDimension {
  PHYSICAL
  MENTAL
  SOCIAL_EMOTIONAL
  SPIRITUAL
}

// ---------------------------------------------------------------------------
// Private Victory: tasks, goals, mission (Habits 1-3)
// ---------------------------------------------------------------------------

model Task {
  id        String  @id @default(cuid())
  title     String
  notes     String?

  // Quadrant is derived from these in the service layer; never stored.
  important Boolean @default(false)
  urgent    Boolean @default(false)

  status      TaskStatus      @default(TODO)
  proactivity ProactivityTag? // Habit 1

  // Habit 3: weekly "big rocks first" planning.
  isBigRock   Boolean   @default(false)
  plannedWeek DateTime? // Monday of the planned week

  dueDate     DateTime?
  completedAt DateTime?

  // The Clock lens: when this actually happens. Independent of quadrant —
  // urgency is a human judgment, deliberately not derived from dates.
  scheduledDay  DateTime? // midnight of the scheduled day
  scheduledTime String?   // optional "HH:MM"

  // Habit 2: a task belongs to at most one Goal (optional, nullable).
  goal   Goal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)
  goalId String?

  // A task belongs to at most one Project; SetNull = deleting a project
  // returns its tasks to the Inbox rather than destroying them.
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId String?

  // Import provenance (Todoist CSV / AI intake).
  source           TaskSource @default(MANUAL)
  externalId       String?
  externalPriority Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([goalId])
  @@index([projectId])
  @@index([status])
  @@index([scheduledDay])
}

// A role the user plays in life (Parent, Professional, Self…). Goals group
// under roles; the link is optional like every link in the hierarchy.
model Role {
  id      String  @id @default(cuid())
  name    String
  // Optional per-role mission line ("Present, not just around.").
  mission String?
  order   Int     @default(0)

  goals Goal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Goal {
  id          String     @id @default(cuid())
  title       String
  description String?
  targetDate  DateTime?
  status      GoalStatus @default(ACTIVE)

  // Goals group under a Role (optional). Deleting a role keeps its goals.
  role   Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  roleId String?

  // Optional link into the Sharpen-the-Saw dimensions (e.g. learning -> MENTAL).
  dimension RenewalDimension?

  tasks    Task[]
  projects Project[]
  habits   Habit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
}

// A multi-step outcome between Goal and Task ("Launch the newsletter").
// Flat — no sub-projects (locked-in decision).
model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)

  // A project serves at most one Goal; unlinked projects are flagged in the
  // UI ("worth doing, or worth dropping?") but never blocked.
  goal   Goal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)
  goalId String?

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([goalId])
}

// Single-user: expect one row with isActive = true.
model MissionStatement {
  id        String   @id @default(cuid())
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Public Victory: people + recurring commitments (Habits 4-6)
// ---------------------------------------------------------------------------

model Person {
  id           String  @id @default(cuid())
  name         String
  // Relationship type is a plain field, not its own entity (deliberate non-case).
  relationship String?
  notes        String?

  commitments CommitmentParticipant[]
  logs        CommitmentLog[]
  ebaEntries  EbaEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Emotional Bank Account (Habits 4-5): deposits and withdrawals per person.
// The balance is DERIVED (deposits - withdrawals), never stored. Coexists with
// the commitment occurrence log — occurrences track cadence, EBA entries track
// relationship quality.
enum EbaKind {
  DEPOSIT
  WITHDRAWAL
}

model EbaEntry {
  id         String   @id @default(cuid())
  person     Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId   String
  kind       EbaKind
  note       String?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([personId, occurredAt])
}

model Commitment {
  id          String  @id @default(cuid())
  title       String
  description String?

  // Shared cadence model (every `cadenceValue` `cadenceUnit`s).
  cadenceUnit  CadenceUnit
  cadenceValue Int         @default(1)

  active Boolean @default(true)

  participants CommitmentParticipant[]
  logs         CommitmentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Many-to-many Commitment <-> Person.
model CommitmentParticipant {
  commitment   Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
  commitmentId String
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId     String

  @@id([commitmentId, personId])
  @@index([personId])
}

// A logged occurrence. personId set => per-person tracking (the chosen default).
model CommitmentLog {
  id           String     @id @default(cuid())
  commitment   Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
  commitmentId String
  person       Person?    @relation(fields: [personId], references: [id], onDelete: SetNull)
  personId     String?
  occurredAt   DateTime   @default(now())
  note         String?
  createdAt    DateTime   @default(now())

  @@index([commitmentId, occurredAt])
  @@index([personId])
}

// ---------------------------------------------------------------------------
// Sharpen the Saw: renewal (Habit 7)
// ---------------------------------------------------------------------------

// A recurring renewal practice. Defined in Compass, checked off in Clock,
// trended in the Almanac. Coexists with one-off RenewalActivity (owner
// decision): dimension aggregates count BOTH; streaks are habit-only.
model Habit {
  id   String @id @default(cuid())
  name String

  // Optional dimension tag — tagged habits feed the renewal aggregates.
  dimension RenewalDimension?

  // Optional goal link — threads habit -> goal -> role, feeds goal momentum.
  goal   Goal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)
  goalId String?

  // Target cadence: daily (7) or N times per week (1-6).
  targetPerWeek Int     @default(7)
  archived      Boolean @default(false)

  marks HabitMark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([goalId])
}

// One check-off per habit per day.
model HabitMark {
  id      String   @id @default(cuid())
  habit   Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  habitId String
  day     DateTime // local midnight of the marked day

  createdAt DateTime @default(now())

  @@unique([habitId, day])
  @@index([day])
}

// A one-line intention per dimension per ISO week ("This week: keep the long
// run, even if it rains."). Intent, never scored. History is kept (owner
// decision) so past intentions become part of the Almanac's record.
model WeeklyIntention {
  id        String           @id @default(cuid())
  dimension RenewalDimension
  weekStart DateTime // Monday (local midnight) of the ISO week
  text      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dimension, weekStart])
}

model RenewalActivity {
  id         String           @id @default(cuid())
  dimension  RenewalDimension
  title      String
  note       String?
  occurredAt DateTime         @default(now())
  createdAt  DateTime         @default(now())

  @@index([dimension, occurredAt])
}

// ---------------------------------------------------------------------------
// Web push (step 9): one subscription row per browser/device, plus a single
// settings row (per-type toggles, quiet hours, last-sent stamps for dedupe).
// ---------------------------------------------------------------------------

model PushSubscription {
  id       String @id @default(cuid())
  endpoint String @unique
  p256dh   String
  auth     String

  createdAt DateTime @default(now())
}

// Single-user: expect one row, created on first read.
model NotificationSettings {
  id String @id @default(cuid())

  overdueCommitments Boolean @default(true)
  morningRocks       Boolean @default(true)
  weeklyReview       Boolean @default(true)

  // Local hours (0-23). Morning reminder fires at morningHour; nothing is
  // sent inside the quiet window (quietStart..quietEnd, wrapping midnight).
  morningHour Int @default(8)
  quietStart  Int @default(22)
  quietEnd    Int @default(8)

  // Dedupe stamps so the scheduler sends each kind at most once per period.
  lastOverdueSentAt DateTime?
  lastMorningSentAt DateTime?
  lastReviewSentAt  DateTime?

  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Auth: API keys (token-based, single-user). Store a hash, never plaintext.
// ---------------------------------------------------------------------------

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  hashedKey  String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}
